from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.action_chains import ActionChains
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.chrome.options import Options

options = Options()
options.add_argument("--start-maximized")

driver = webdriver.Chrome(options=options)
driver.set_page_load_timeout(30)

wait = WebDriverWait(driver, 15)
actions = ActionChains(driver)

driver.get("https://www.testmuai.com/selenium-playground/hover-demo/")

image = wait.until(EC.presence_of_element_located((
    By.XPATH,
    "//img[@src='https://picsum.photos/300/200?image=244']"
)))

actions.move_to_element(image).perform()

visible_text = wait.until(EC.visibility_of_element_located((
    By.XPATH, "//p[text()='Hover']"
)))

print("After Hover, visible text is:", visible_text.text)

driver.quit()

# Zoom In
from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.action_chains import ActionChains
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.chrome.options import Options

options = Options()
options.add_argument("--start-maximized")

driver = webdriver.Chrome(options=options)
wait = WebDriverWait(driver, 15)
actions = ActionChains(driver)

driver.get("https://www.testmuai.com/selenium-playground/hover-demo/")

locator = (By.XPATH, "//div[@class='image-card']/img")

# 🔥 always fresh element
image = wait.until(EC.visibility_of_element_located(locator))
before = driver.find_element(*locator).value_of_css_property("transform")

actions.move_to_element(image).perform()

# 🔥 re-fetch after hover
after = driver.find_element(*locator).value_of_css_property("transform")

print("Before:", before)
print("After:", after)

driver.quit()